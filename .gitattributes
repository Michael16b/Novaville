# Ensure consistent line endings across all platforms
* text=auto

# Shell scripts: always LF (Unix line endings)
*.sh text eol=lf
docker-entrypoint.sh text eol=lf
backend/docker-entrypoint.sh text eol=lf
wait_for_db.py text eol=lf

# Python files: LF
*.py text eol=lf

# Dart files: LF
*.dart text eol=lf

# YAML files: LF
*.yml text eol=lf
*.yaml text eol=lf

# JSON: LF
*.json text eol=lf

# Markdown: LF
*.md text eol=lf

# Windows batch files: CRLF (if needed)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.so binary
*.dylib binary
