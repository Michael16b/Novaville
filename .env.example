# Variables d'environnement pour docker-compose
# Copier ce fichier en .env et adapter les valeurs

# Backend Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_WSGI_MODULE=config.wsgi
DJANGO_SECRET_KEY=CHANGE_ME_TO_AT_LEAST_32_CHARS
JWT_SIGNING_KEY=CHANGE_ME_TO_AT_LEAST_32_CHARS

# Base de données CloudSQL / PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=novaville_db
DB_USER=novaville_user
DB_PASSWORD=YOUR_SECURE_PASSWORD

# CloudSQL Instance Connection Name (si utilisation de sockets)
# INSTANCE_CONNECTION_NAME=PROJECT:REGION:INSTANCE

# Frontend Flutter
API_URL=http://localhost:8000
ENVIRONMENT=production
