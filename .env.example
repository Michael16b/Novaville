# Variables d'environnement pour docker-compose
# Copier ce fichier en .env et adapter les valeurs

# Backend Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_WSGI_MODULE=config.wsgi
DJANGO_SECRET_KEY=CHANGE_ME_TO_AT_LEAST_32_CHARS
JWT_SIGNING_KEY=CHANGE_ME_TO_AT_LEAST_32_CHARS

# Compte administrateur Django (créé automatiquement au démarrage si absent)
# DJANGO_SUPERUSER_PASSWORD est OBLIGATOIRE pour activer la création automatique
# Sans cette variable, aucun compte admin ne sera créé au démarrage
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@novaville.fr
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Optionnel (prod): force la suppression/recreation du compte admin a chaque deploy
# Valeurs: 0 (desactive) / 1 (active)
DJANGO_RESET_ADMIN_ON_DEPLOY=0

# Base de données CloudSQL / PostgreSQL
# DB_PASSWORD est OBLIGATOIRE – doit correspondre au mot de passe PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=novaville_db
DB_USER=novaville_user
DB_PASSWORD=YOUR_SECURE_PASSWORD

# CloudSQL Instance Connection Name (si utilisation de sockets)
# INSTANCE_CONNECTION_NAME=PROJECT:REGION:INSTANCE

# Frontend Flutter
API_URL=http://localhost:8000
ENVIRONMENT=production
