# Variables d'environnement pour docker-compose
# ⚠️  CRITICAL FOR BEGINNERS:
# 1. Copy this file to .env
# 2. Replace ALL values below with your own secure values
# 3. DB_PASSWORD and DJANGO_SUPERUSER_PASSWORD MUST be set or docker will fail
# 4. Never commit .env to Git (it's in .gitignore)

# Backend Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_WSGI_MODULE=config.wsgi
# CHANGE THESE TO RANDOM 50+ CHARACTER STRINGS FOR PRODUCTION!
DJANGO_SECRET_KEY=dev-only-unsafe-change-to-50-random-chars-in-production
JWT_SIGNING_KEY=dev-only-unsafe-change-to-50-random-chars-in-production

# Compte administrateur Django (créé automatiquement au démarrage)
# ⚠️  MUST be set, or the admin account won't be created
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@novaville.fr
DJANGO_SUPERUSER_PASSWORD=ChangeMe123456
# Optionnel (prod): force la suppression/recreation du compte admin a chaque deploy
DJANGO_RESET_ADMIN_ON_DEPLOY=0

# Base de données PostgreSQL
# ⚠️  DB_PASSWORD MUST be set or connections will fail with "fe_sendauth: no password supplied"
DB_ENGINE=django.db.backends.postgresql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=novaville_db
DB_USER=novaville_user
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE

# Frontend Flutter
API_URL=http://localhost:8000
ENVIRONMENT=production

